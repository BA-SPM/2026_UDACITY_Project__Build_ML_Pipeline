name: nyc_airbnb
# NOTE: env_manager set to 'local' for all mlflow.run() calls in main.py.
# Reason: Corporate firewall blocks conda-forge channel (HTTP 000).
#
# For remote execution (mlflow run <github-url>), python_env is used:
# - Creates a virtualenv with pip (no conda/admin required)
# - Installs dependencies from requirements.txt
#
# Local: python main.py ...               (uses active .venv)
# Remote: mlflow run <url> -v 1.0.0 ...   (creates virtualenv from python_env)
python_env: python_env.yaml

entry_points:
  main:
    parameters:

      steps:
        description: Comma-separated list of steps to execute (useful for debugging)
        type: str
        default: all

      hydra_options:
        description: Other configuration parameters to override
        type: str
        default: ''

    command: "python main.py main.steps={steps} {hydra_options}"
