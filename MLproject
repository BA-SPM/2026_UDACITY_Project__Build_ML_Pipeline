name: nyc_airbnb
# NOTE: env_manager set to 'local' for all mlflow.run() calls.
# Reason: Corporate firewall blocks conda-forge channel (HTTP 000).
# All required packages must be present in the active Python environment.
# See environment.yml for the full list of required packages.
# To set up the environment: pip install -r requirements.txt (or use .venv)
# conda_env: conda.yml  <- disabled: use env_manager='local' instead

entry_points:
  main:
    parameters:

      steps:
        description: Comma-separated list of steps to execute (useful for debugging)
        type: str
        default: all

      hydra_options:
        description: Other configuration parameters to override
        type: str
        default: ''

    command: "python main.py main.steps={steps}"
