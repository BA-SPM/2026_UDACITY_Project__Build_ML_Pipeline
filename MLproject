name: nyc_airbnb
# NOTE: env_manager set to 'local' for all mlflow.run() calls in main.py.
# Reason: Corporate firewall blocks conda-forge channel (HTTP 000).
#
# For local execution, `mlflow run .` will use the Conda environment defined below.
# The Conda file is the source of truth for the project runtime dependencies.
conda_env: conda.yml

entry_points:
  main:
    parameters:

      steps:
        description: Comma-separated list of steps to execute (useful for debugging)
        type: str
        default: all

      hydra_options:
        description: Other configuration parameters to override
        type: str
        default: ''

    command: "python main.py main.steps={steps} {hydra_options}"
