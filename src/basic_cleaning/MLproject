name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: Fully-qualified name of the input artifact to clean
        type: string

      output_artifact:
        description: Name for the cleaned output artifact
        type: string

      output_type:
        description: W&B artifact type for the cleaned dataset
        type: string

      output_description:
        description: Description of the cleaned output artifact
        type: string

      min_price:
        description: Minimum allowed price (inclusive)
        type: float

      max_price:
        description: Maximum allowed price (inclusive)
        type: float


    command: >-
        python run.py  --input_artifact {input_artifact}  --output_artifact {output_artifact}  --output_type {output_type}  --output_description {output_description}  --min_price {min_price}  --max_price {max_price} 
